rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions for Security
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidString(text, maxLength) {
      return text is string && text.size() > 0 && text.size() <= maxLength;
    }

    match /users/{userId} {
      // Basic profile write rules
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);

      match /agents/{agentId} {
        // Only owner can read/write their agents
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
                      && request.resource.data.keys().hasAll(['id', 'name', 'blueprint'])
                      && isValidString(request.resource.data.name, 100);
        allow update: if isOwner(userId)
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'blueprint', 'updatedAt']);
        allow delete: if isOwner(userId);
      }

      match /memories/{memoryId} {
        // Only owner can read/write memories
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
                      && request.resource.data.keys().hasAll(['content', 'createdAt']);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }

    // Deny all other collections to prevent unwanted access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
